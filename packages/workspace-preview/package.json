  "exports": {
    ".": {
      "types": "./src/index.d.mts",
      "import": "./src/index.mjs"
    },
    "./safety": {
      "types": "./src/safety.d.mts",
      "import": "./src/safety.mjs"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test test/*.test.mjs",
    "clean": "rm -rf .tsbuildinfo"
  }
}
